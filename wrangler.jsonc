/**
 * For more details on how to configure Wrangler, refer to:
 * - https://developers.cloudflare.com/workers/wrangler/configuration
 * - https://developers.cloudflare.com/workers/runtime-apis/bindings
 * - https://developers.cloudflare.com/workers/static-assets/binding
 *
 * Build configurations:
 * - Build command: `pnpm run typegen && pnpm run build`
 * - Deploy command: `pnpm exec wrangler deploy --env production`
 * - Non-production branch deploy command: `pnpm exec wrangler versions upload`
 *
 * Envar for build only (Settings -> Build -> Variables and secrets):
 * - PUBLIC_ or VITE_ prefixed variables need to added here!
 */
{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "tanstart",
    "compatibility_date": "2026-04-07",
    "compatibility_flags": ["nodejs_compat"],
    "main": "@tanstack/react-start/server-entry",
    "send_metrics": false,
    "preview_urls": true,
    "dev": {
        "host": "127.0.0.1",
        "port": 3000
    },
    // "routes": [
    //     {
    //         "pattern": "example.com",
    //         "custom_domain": true
    //     }
    // ],
    "placement": {
        "mode": "smart"
    },
    "observability": {
        "enabled": true,
        "head_sampling_rate": 0.01,
        "logs": {
            "enabled": true,
            "head_sampling_rate": 0.7
        }
    },
    "vars": {
        /* Settings -> Variables and secrets */
        "NODE_VERSION": "24.14.1",
        "PNPM_VERSION": "10.33.0"
    }
}
