{
  "name": "better-start",
  "version": "0.0.0",
  "private": true,
  "description": "Faster way to start building your MVP application",
  "homepage": "https://github.com/riipandi/better-start#readme",
  "bugs": {
    "url": "https://github.com/riipandi/better-start/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riipandi/better-start.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite dev --port 3000",
    "auth:secret": "pnpm dlx auth@latest secret",
    "auth:migrate": "pnpm dlx auth@latest migrate --config ./src/lib/auth.ts",
    "auth:generate": "pnpm dlx auth@latest generate --config ./src/lib/auth.ts",
    "start": "PORT=3000 node --env-file-if-exists=.env.local .output/server/index.mjs",
    "docker:build": "docker build -f ./deploy/Dockerfile.distroless . --build-arg DISTROLESS_TAG=debug-nonroot -t $npm_package_config_image:$npm_package_version-dev",
    "docker:push": "docker push $npm_package_config_image:latest-dev && docker push $npm_package_config_image:$npm_package_version-dev",
    "docker:run": "pnpm --silent run dockerx --name $npm_package_name $npm_package_config_image:$npm_package_version-dev",
    "docker:shell": "pnpm --silent run dockerx --entrypoint sh $npm_package_config_image:$npm_package_version-dev",
    "docker:prune": "docker image rm --force $(docker image list --filter reference=$npm_package_config_image:* -q)",
    "docker:images": "docker image list --filter reference=$npm_package_config_image:*",
    "compose:up": "docker compose -f compose.yaml up --detach --remove-orphans",
    "compose:down": "docker compose -f compose.yaml down --remove-orphans",
    "compose:cleanup": "docker compose -f compose.yaml down --remove-orphans --volumes",
    "compose:restart": "pnpm --silent run compose:down && pnpm --silent run compose:up",
    "cleanup": "pnpm dlx del-cli .{output,tanstack,wrangler} storybook-static pnpm-lock.yaml node_modules",
    "update-deps": "npm-check-updates --configFileName .ncurc.json",
    "storybook": "storybook dev -p 6006 --no-open",
    "storybook:build": "storybook build",
    "storybook:start": "pnpm dlx serve storybook-static -l 6006 -S -n -C",
    "e2e-install": "playwright install chromium --with-deps",
    "e2e-chrome": "playwright test --headed --project Chromium",
    "e2e-firefox": "playwright test --headed --project Firefox",
    "e2e-mobile": "playwright test --headed --project 'Mobile Chrome'",
    "e2e-safari": "playwright test --headed --project Safari",
    "e2e-report": "playwright show-report .build/e2e-result",
    "e2e-ui": "playwright test --ui",
    "e2e": "playwright test",
    "test:report": "pnpm dlx serve output/test-result -l 8000 -s -n -C",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test": "vitest --run",
    "typecheck": "tsc -b --noEmit --extendedDiagnostics",
    "knip": "knip -c .knip.jsonc --reporter markdown --no-exit-code",
    "check": "oxfmt --check && oxlint",
    "format": "oxfmt --write .",
    "lint": "oxlint --fix"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@noble/hashes": "^2.0.1",
    "@tanstack/devtools-vite": "^0.5.2",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-devtools": "^0.9.6",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-devtools": "^1.163.3",
    "@tanstack/react-router-ssr-query": "^1.163.3",
    "@tanstack/react-start": "^1.164.1",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.164.0",
    "@trpc/client": "^11.11.0",
    "@trpc/server": "^11.11.0",
    "@trpc/tanstack-react-query": "^11.11.0",
    "better-auth": "^1.5.0",
    "kysely": "^0.28.11",
    "lucide-react": "^0.575.0",
    "pg": "^8.19.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.6",
    "typeid-js": "^1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-vitest": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "git-cliff": "^2.12.0",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "lefthook": "^2.1.1",
    "nitro": "npm:nitro-nightly@latest",
    "npm-check-updates": "^19.6.3",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "playwright": "^1.58.2",
    "storybook": "^10.2.13",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0"
  },
  "config": {
    "image": "ghcr.io/riipandi/better-start"
  },
  "engines": {
    "node": ">=24.12.0"
  },
  "packageManager": "pnpm@10.30.3"
}
