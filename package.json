{
    "name": "better-start",
    "type": "module",
    "sideEffects": false,
    "private": true,
    "scripts": {
        "dev": "vite dev",
        "build": "vite build && fumadocs-mdx",
        "start": "PORT=3000 node --env-file-if-exists=.env.local .output/server/index.mjs",
        "auth:generate": "NODE_NO_WARNINGS=1 better-auth generate --config ./src/libraries/auth.server.ts",
        "auth:migrate": "NODE_NO_WARNINGS=1 better-auth migrate --config ./src/libraries/auth.server.ts",
        "compose:cleanup": "docker compose -f compose.yaml down --remove-orphans --volumes",
        "compose:up": "docker compose -f compose.yaml up --detach --remove-orphans",
        "compose:down": "docker compose -f compose.yaml down --remove-orphans",
        "cleanup": "pnpm dlx del-cli .{output,wrangler} pnpm-lock.yaml node_modules",
        "update-deps": "npm-check-updates --configFileName .ncurc.json",
        "postinstall": "fumadocs-mdx",
        "check": "biome check . --write",
        "format": "biome format . --write",
        "lint": "biome lint . --write",
        "typecheck": "tsc -b --noEmit"
    },
    "dependencies": {
        "@better-auth/passkey": "^1.4.9",
        "@daveyplate/better-auth-ui": "^3.3.9",
        "@libsql/kysely-libsql": "^0.4.1",
        "@tanstack/react-query": "^5.90.21",
        "@tanstack/react-router": "1.136.18",
        "@tanstack/react-router-devtools": "1.163.3",
        "@tanstack/react-start": "1.136.18",
        "better-auth": "~1.4.9",
        "consola": "^3.4.2",
        "fumadocs-core": "16.3.2",
        "fumadocs-mdx": "14.2.2",
        "fumadocs-ui": "16.3.2",
        "kysely": "^0.28.11",
        "lucide-react": "^0.575.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "std-env": "^3.10.0",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0"
    },
    "devDependencies": {
        "@better-auth/cli": "^1.4.9",
        "@biomejs/biome": "^2.3.10",
        "@tailwindcss/vite": "^4.2.1",
        "@types/mdx": "^2.0.13",
        "@types/node": "^25.3.3",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "nitro": "3.0.1-alpha.2",
        "npm-check-updates": "^19.6.3",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^6.1.1"
    }
}
