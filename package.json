{
    "name": "tanstart",
    "version": "0.0.0",
    "private": true,
    "homepage": "https://github.com/riipandi/tanstart#readme",
    "bugs": {
        "url": "https://github.com/riipandi/tanstart/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/riipandi/tanstart.git"
    },
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "wrangler dev",
        "deploy": "wrangler deploy",
        "typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
        "start": "PORT=3000 node --env-file-if-exists=.env.local ./dist/server/server.js",
        "update-deps": "npm-check-updates --configFileName .ncurc.json",
        "cleanup": "pnpm --silent cleanup:dist && pnpm --silent cleanup:deps",
        "cleanup:dist": "pnpm dlx del-cli dist storybook-static e2e-result",
        "cleanup:deps": "pnpm dlx del-cli .{tanstack,wrangler} pnpm-lock.yaml node_modules",
        "generate:key": "openssl rand -hex 32",
        "storybook": "storybook dev -p 6006 --no-open",
        "storybook:build": "storybook build",
        "storybook:start": "pnpm dlx serve storybook-static -l 6006 -S -n -C",
        "e2e-install": "playwright install chromium --with-deps",
        "e2e-chrome": "playwright test --headed --project Chromium",
        "e2e-firefox": "playwright test --headed --project Firefox",
        "e2e-mobile": "playwright test --headed --project 'Mobile Chrome'",
        "e2e-safari": "playwright test --headed --project Safari",
        "e2e-report": "playwright show-report e2e-result",
        "e2e-ui": "playwright test --ui",
        "e2e": "playwright test",
        "test:report": "pnpm dlx serve output/test-result -l 8000 -s -n -C",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test": "vitest --run",
        "knip": "knip -c .knip.jsonc --reporter markdown --no-exit-code",
        "format": "oxfmt --write .",
        "check": "oxfmt --check",
        "lint": "oxlint --fix .",
        "typecheck": "tsc -b --noEmit"
    },
    "dependencies": {
        "@lonik/themer": "^0.5.4",
        "@tanstack/react-query": "^5.96.0",
        "@tanstack/react-router": "^1.168.10",
        "@tanstack/react-router-ssr-query": "^1.166.10",
        "@tanstack/react-start": "^1.167.16",
        "@tanstack/react-store": "^0.9.3",
        "@tanstack/router-plugin": "^1.167.12",
        "lucide-react": "^1.7.0",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwind-merge": "^3.5.0",
        "tailwind-variants": "^3.2.2",
        "tailwindcss": "^4.2.2",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.30.3",
        "@tailwindcss/vite": "^4.2.2",
        "@tanstack/devtools-vite": "^0.6.0",
        "@tanstack/react-devtools": "^0.10.0",
        "@tanstack/react-query-devtools": "^5.96.0",
        "@tanstack/react-router-devtools": "^1.166.11",
        "@tanstack/router-plugin": "^1.167.12",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "dotenv-cli": "^11.0.0",
        "kill-port-process-cli": "^1.0.16",
        "knip": "^6.1.1",
        "npm-check-updates": "^19.6.6",
        "oxfmt": "^0.43.0",
        "oxlint": "^1.58.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.3",
        "vitest": "^4.1.2",
        "wrangler": "^4.79.0"
    },
    "config": {
        "image": "ghcr.io/riipandi/tanstart"
    },
    "engines": {
        "node": ">=24.12.0"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "lightningcss",
            "sharp",
            "workerd"
        ]
    }
}
